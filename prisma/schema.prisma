// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   // "INFLUENCER" | "COMPANY" | "ADMIN"
  createdAt DateTime @default(now())

  influencerProfile InfluencerProfile?
  companyProfile    CompanyProfile?
  sentDeals         Deal[] @relation("CompanyDeals")
  receivedDeals     Deal[] @relation("InfluencerDeals")
  sentMessages      DealMessage[] @relation("SentMessages")
}

model InfluencerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name   String
  bio    String
  avatar String?
  niche  String
  phone  String?

  status String @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"

  instagram String?
  youtube   String?
  twitter   String?
  tiktok    String?
  linkedin  String?
  facebook  String?
  contactEmail String?

  instagramFollowers Int?
  youtubeFollowers   Int?
  twitterFollowers   Int?
  tiktokFollowers    Int?
  facebookFollowers  Int?

  ratePerPost Float
  currency    String  @default("INR")
  location    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyProfile {
  id      String @id @default(cuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName String
  industry    String
  website     String?
  description String
  budget      String
  phone       String?

  status String @default("APPROVED") // Companies auto-approved

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model Deal {
  id           String @id @default(cuid())
  companyId    String
  influencerId String
  company      User   @relation("CompanyDeals",    fields: [companyId],    references: [id], onDelete: Cascade)
  influencer   User   @relation("InfluencerDeals", fields: [influencerId], references: [id], onDelete: Cascade)

  title       String
  description String
  dealValue   Float
  commission  Float
  status      String @default("PENDING")

  messages    DealMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DealMessage {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}
